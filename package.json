{
  "name": "boss-agent-workspace",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix frontend\" \"uvicorn backend.app.main:app --reload --port 8000\"",
    "frontend:dev": "npm run dev --prefix frontend",
    "backend:dev": "uvicorn backend.app.main:app --reload --port 8000",
    "backend:login": "python -m backend.app.worker_cli login",
    "backend:status": "python -m backend.app.worker_cli status",
    "backend:collect": "python -m backend.app.worker_cli collect --keyword 前端",
    "backend:sync": "python -m backend.app.worker_cli sync-messages",
    "playwright:install": "python -m playwright install chromium",
    "frontend:build": "npm run build --prefix frontend",
    "frontend:lint": "npm run lint --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
